# ═══════════════════════════════════════════════
#  EduChain Protocol – Variáveis de Ambiente
# ═══════════════════════════════════════════════

# Chave privada da conta deployer (SEM o prefixo 0x)
PRIVATE_KEY=sua_chave_privada_aqui

# RPC URLs
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/SEU_PROJECT_ID
MUMBAI_RPC_URL=https://polygon-mumbai.infura.io/v3/SEU_PROJECT_ID

# Verificação de contratos
ETHERSCAN_API_KEY=sua_chave_etherscan
POLYGONSCAN_API_KEY=sua_chave_polygonscan

# Relatório de gas (opcional)
REPORT_GAS=false
COINMARKETCAP_API_KEY=
